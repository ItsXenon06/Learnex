# =============================================================
#  Learnex — .gitignore
#  Monorepo: frontend (Vite/React) + backend (Spring Boot/Maven)
# =============================================================

# =============================================================
# ENVIRONMENT & SECRETS  ← never commit these
# =============================================================
.env
.env.*
!.env.example          # allow the template file if you have one
*.pem
*.key
*.p12
*.jks


# =============================================================
# FRONTEND — Node / Vite / React
# =============================================================
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.cache/

# Local Vite env overrides (keep .env.example in VCS)
frontend/.env.local
frontend/.env.*.local

# Editor / OS
frontend/.DS_Store
frontend/Thumbs.db


# =============================================================
# BACKEND — Java / Maven / Spring Boot
# =============================================================

# Maven build output
backend/target/
backend/.mvn/wrapper/maven-wrapper.jar   # generated; only keep .properties

# Spring Boot packaged jars
backend/*.jar
backend/*.war

# Maven local repo cache (if accidentally placed inside the project)
backend/.m2/

# Spring DevTools restart file
backend/.spring-boot-devtools.properties

# Application secrets / overrides (keep application.properties in VCS,
# but override files with real credentials stay local)
backend/src/main/resources/application-local.properties
backend/src/main/resources/application-prod.properties
backend/src/main/resources/application-secret.properties


# =============================================================
# IDEs & EDITORS
# =============================================================

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/

# VS Code
.vscode/
!.vscode/extensions.json   # allow recommended extensions list

# Eclipse / STS
.classpath
.project
.settings/
bin/

# NetBeans
nbproject/
nbbuild/
dist/
nbdist/
.nb-gradle/

node_modules
# =============================================================
# OPERATING SYSTEM
# =============================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini


# =============================================================
# LOGS & TEMP FILES
# =============================================================
*.log
logs/
*.tmp
*.temp
*.swp
*.swo
*~


# =============================================================
# TESTING & COVERAGE
# =============================================================
backend/src/test/resources/application-test.properties
coverage/
*.lcov
backend/target/surefire-reports/
backend/target/jacoco.exec


# =============================================================
# DOCKER (if added later)
# =============================================================
# docker-compose.override.yml